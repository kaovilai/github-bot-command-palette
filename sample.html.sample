      #claude-agent-stop-button {
        background: #4285F422 !important;
        border-color: #4285F466 !important;
        box-shadow: 0 40px 80px rgba(66, 133, 244, 0.24), 0 4px 14px rgba(66, 133, 244, 0.24) !important;
      }
      #claude-agent-stop-button:hover {
        background: #4285F433 !important;
        box-shadow: 0 40px 80px rgba(66, 133, 244, 0.24), 0 4px 14px rgba(66, 133, 244, 0.24) !important;
      }

      
      @keyframes claude-pulse {
        0% {
          box-shadow:
            inset 0 0 25px rgba(66, 133, 244, 0.95),
            inset 0 0 50px rgba(66, 133, 244, 0.6),
            inset 0 0 80px rgba(66, 133, 244, 0.2);
          outline: 3px solid rgba(66, 133, 244, 0.7);
        }
        50% {
          box-shadow:
            inset 0 0 35px rgba(66, 133, 244, 1),
            inset 0 0 70px rgba(66, 133, 244, 0.75),
            inset 0 0 110px rgba(66, 133, 244, 0.35);
          outline: 3px solid rgba(66, 133, 244, 0.9);
        }
        100% {
          box-shadow:
            inset 0 0 25px rgba(66, 133, 244, 0.95),
            inset 0 0 50px rgba(66, 133, 244, 0.6),
            inset 0 0 80px rgba(66, 133, 244, 0.2);
          outline: 3px solid rgba(66, 133, 244, 0.7);
        }
      }
    

      #claude-agent-glow-border {
        box-shadow:
          inset 0 0 25px rgba(66, 133, 244, 0.95),
          inset 0 0 50px rgba(66, 133, 244, 0.6),
          inset 0 0 80px rgba(66, 133, 244, 0.2) !important;
        outline: 3px solid rgba(66, 133, 244, 0.7) !important;
        outline-offset: -3px !important;
      }
    </style></head>

